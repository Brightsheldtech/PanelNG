# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# JustAnotherPanel SMM API
JAP_API_KEY=your_jap_api_key_here
JAP_API_URL=https://justanotherpanel.com/api/v2

# HeroSMS API
HEROSMS_API_KEY=your_herosms_api_key_here
HEROSMS_API_URL=https://hero-sms.com/api/v1

# Paystack
PAYSTACK_SECRET_KEY=sk_live_your_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_live_your_public_key_here

# App
FRONTEND_URL=http://localhost:5173
PORT=3001
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars

# Gmail SMTP — for admin payment notifications
# 1. Enable 2FA on Gmail
# 2. Google Account → Security → App passwords → create one named "PanelNG"
# 3. Paste the 16-char app password (no spaces) below
ADMIN_EMAIL=your_admin_email@gmail.com
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx
